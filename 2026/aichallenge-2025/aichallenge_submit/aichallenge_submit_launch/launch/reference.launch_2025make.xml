<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- Essential parameters -->
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)" description="vehicle specific ID"/>
  <arg name="simulation" description="used for sensor kit param"/>
  <arg name="use_sim_time"/>
  <arg name="map_path" default="$(find-pkg-share aichallenge_submit_launch)/map"/>
  <arg name="vehicle_model" default="racing_kart"  description="vehicle model name"/>
  <arg name="sensor_model" default="racing_kart_sensor_kit" description="sensor model name"/>
  <!-- Optional parameters -->
  <!-- Map -->
  <arg name="lanelet2_map_file" default="lanelet2_map.osm" description="lanelet2 map file name"/>
  <arg name="pointcloud_map_file" default="pointcloud_map.pcd" description="pointcloud map file name"/>

  <!-- Vehicle -->
  <arg name="launch_vehicle_interface" default="false"/>
  <log message="echo launch param use_sim_time: $(var use_sim_time) launch_vehicle_interface: $(var launch_vehicle_interface) sensor_model: $(var sensor_model)"/>

  <!-- Global parameters -->
  <group scoped="false">
    <include file="$(find-pkg-share global_parameter_loader)/launch/global_params.launch.py">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="vehicle_model" value="$(var vehicle_model)"/>
    </include>
  </group>

  <group>
    <arg name="model_file" default="$(find-pkg-share tier4_vehicle_launch)/urdf/vehicle.xacro" description="path to the file of model settings (*.xacro)"/>
    <arg name="config_dir" default="$(find-pkg-share racing_kart_sensor_kit_description)/config"/>
    <node name="robot_state_publisher" pkg="robot_state_publisher" exec="robot_state_publisher">
      <param name="robot_description" value="$(command 'xacro $(var model_file) vehicle_model:=$(var vehicle_model) sensor_model:=$(var sensor_model) config_dir:=$(var config_dir) simulation:=$(var simulation)' 'warn')"/>
    </node>
  </group>

  <!-- Sensing -->
  <group>
    <push-ros-namespace namespace="sensing"/>
    <!-- Vehicle Velocity Converter  -->
    <include file="$(find-pkg-share vehicle_velocity_converter)/launch/vehicle_velocity_converter.launch.xml">
      <arg name="input_vehicle_velocity_topic" value="/vehicle/status/velocity_status"/>
      <arg name="output_twist_with_covariance" value="/sensing/vehicle_velocity_converter/twist_with_covariance"/>
      <arg name="config_file" value="$(find-pkg-share aichallenge_submit_launch)/config/vehicle_velocity_converter.param.yaml"/>
    </include>
    <group>
      <push-ros-namespace namespace="imu"/>
      <arg name="imu_corrector_param_file" default="$(find-pkg-share imu_corrector)/config/imu_corrector.param.yaml"/>
      <include file="$(find-pkg-share imu_corrector)/launch/imu_corrector.launch.xml">
        <arg name="input_topic" value="imu_raw"/>
        <arg name="output_topic" value="imu_data"/>
        <arg name="param_file" value="$(var imu_corrector_param_file)"/>
      </include>
    </group>
    <group>
      <push-ros-namespace namespace="gnss"/>
      <include file="$(find-pkg-share racing_kart_gnss_poser)/launch/gnss_poser.launch.xml">
        <arg name="input_topic_fix" value="nav_sat_fix"/>
        <arg name="output_topic_gnss_pose" value="pose"/>
        <arg name="output_topic_gnss_fixed" value="gnss_fixed"/>
        <arg name="output_topic_gnss_pose_cov" value="pose_with_covariance"/>
      </include>
    </group>
  </group>

    <!-- Localization -->
  <let name="pose_additional_delay_var" value="0.3" />
  <group>
    <push-ros-namespace namespace="localization"/>
    <include file="$(find-pkg-share gyro_odometer)/launch/gyro_odometer.launch.xml">
      <arg name="input_vehicle_twist_with_covariance_topic" value="/sensing/vehicle_velocity_converter/twist_with_covariance"/>
      <arg name="input_imu_topic" value="/sensing/imu/imu_data"/>
      <arg name="output_twist_with_covariance_topic" value="/localization/twist_estimator/twist_with_covariance"/>
      <arg name="output_twist_with_covariance_raw_topic" value="/localization/twist_estimator/twist_with_covariance_raw"/>
    </include>

    <node pkg="imu_gnss_poser" exec="imu_gnss_poser_node" name="imu_gnss_poser" output="screen"/>

    <include file="$(find-pkg-share ekf_localizer)/launch/ekf_localizer.launch.xml">
      <arg name="enable_yaw_bias_estimation" value="false"/>
      <arg name="tf_rate" value="30.0"/>
      <arg name="twist_smoothing_steps" value="1"/>
      <arg name="pose_smoothing_steps" value="1"/>
      <arg name="input_initial_pose_name" value="/localization/initial_pose3d"/>
      <arg name="input_pose_with_cov_name" value="/localization/imu_gnss_poser/pose_with_covariance"/>
      <arg name="input_twist_with_cov_name" value="/localization/twist_estimator/twist_with_covariance"/>
      <arg name="output_odom_name" value="kinematic_state"/>
      <arg name="output_pose_name" value="pose"/>
      <arg name="output_pose_with_covariance_name" value="/localization/pose_with_covariance"/>
      <arg name="output_biased_pose_name" value="biased_pose"/>
      <arg name="output_biased_pose_with_covariance_name" value="biased_pose_with_covariance"/>
      <arg name="output_twist_name" value="twist"/>
      <arg name="output_twist_with_covariance_name" value="twist_with_covariance"/>
      <arg name="proc_stddev_vx_c" value="10.0"/>
      <arg name="proc_stddev_wz_c" value="5.0"/>
      <arg name="pose_additional_delay" value="$(var pose_additional_delay_var)"/>
      <arg name="extend_state_step" value="100"/>
    </include>

    <!-- twist2accel -->
    <group>
      <node pkg="twist2accel" exec="twist2accel" name="twist2accel" output="screen">
        <param name="accel_lowpass_gain" value="0.9"/>
        <param name="use_odom" value="true"/>
        <remap from="input/odom" to="/localization/kinematic_state"/>
        <remap from="input/twist" to="/localization/twist_estimator/twist_with_covariance"/>
        <remap from="output/accel" to="/localization/acceleration"/>
      </node>
    </group>

  </group>

  <!-- Planning -->
  <group>
    <push-ros-namespace namespace="planning"/>
    <!-- scenario_planning -->
    <group>
      <push-ros-namespace namespace="scenario_planning"/>
      <!-- Customizable -->
      <node pkg="simple_trajectory_generator" exec="simple_trajectory_generator_node" name="simple_trajectory_generator" output="screen">
            <param name="pitlane_trajectory" value="$(find-pkg-share simple_trajectory_generator)/data/raceline_aio_fg.csv"/>
            <param name="raceline_trajectory" value="$(find-pkg-share simple_trajectory_generator)/data/raceline_aio.csv"/>
            <param name="z" value="6.5"/>
            <param name="use_lap_switching" value="true"/>
      </node>
    </group>
  </group>

  <!-- Pure Pursuit -->
  <let name="steering_tire_angle_gain_var" value="1.9" if="$(var simulation)"/>
  <let name="steering_tire_angle_gain_var" value="3.639" unless="$(var simulation)"/>

<node pkg="simple_pure_pursuit" exec="simple_pure_pursuit" name="simple_pure_pursuit_node" output="screen">
  <param name="use_external_target_vel" value="false"/>
  <param name="external_target_vel" value="12.0"/>
  <!-- =========================== -->
  <!-- LQR/ハイブリッド制御パラメータ  -->  
  <!-- =========================== -->
  <!-- 制御方式選択 -->
  <param name="use_trajectory_based_control" value="true"/>   <!-- 軌道種別による制御切り替え: true=軌道に応じた制御, false=従来方式 -->
  <param name="use_lqr_control" value="true"/>                <!-- LQR制御の有効化                  : true=LQR+PP, False=PPのみ -->
  <param name="always_use_lqr" value="true"/>                 <!-- 常時LQR切替                     : true=速度条件のみでLQR, False=曲率+速度条件でハイブリッド -->
  <param name="lqr_curvature_threshold" value="-0.01"/>       <!-- LQR切替許可する曲率閾値 [rad/m]   : 大きくするとLQR発動条件が厳しくなる（急カーブのみ） -->
  <param name="lqr_min_speed_ms" value="-0.01"/>              <!-- LQR切替許可する最小速度 [m/s]     : 大きくするとLQR発動速度が上がる（高速時のみLQR） -->
  <param name="lqr_lateral_error_threshold" value="0.8"/>     <!-- LQR切替許可する横方向偏差閾値 [m]  : この値未満で安定と判定してLQR切替許可 -->
  <param name="lqr_heading_error_threshold" value="0.3"/>     <!-- LQR切替許可するヨー角偏差閾値 [rad]: この値未満で安定と判定してLQR切替許可 -->
  <!-- 制御パラメータ -->
  <param name="control_frequency" value="80.0"/>              <!-- 制御周波数 [Hz]: 大きくするとより高頻度で制御計算（CPU負荷増） -->
  <!-- CSV出力設定 -->
  <param name="enable_csv_output" value="true"/>              <!-- CSV出力有効化: true=制御ログ記録, false=ログなし -->
  <param name="csv_save_interval" value="1.0"/>               <!-- CSV保存間隔 [sec]: 小さくするとより頻繁に保存（I/O負荷増） -->

  <!-- Pure Pursuit 制御 -->
  <!-- lookahead_distance = lookahead_gain_ * target_longitudinal_vel + lookahead_min_distance -->
  <param name="lookahead_gain" value="0.6"/>
  <param name="lookahead_min_distance"   value="3.0"/>
  <param name="speed_proportional_gain"  value="1.15"/>
  <param name="steering_tire_angle_gain" value="$(var steering_tire_angle_gain_var)"/>
  
  <!-- LQR 制御 -->
  <!-- 速度閾値 (km/h) - LQRパラメータ切り替え用 -->
  <param name="speed_threshold_low"  value="27.0"/>           <!-- 低速域上限[km/h] : この値未満で低速LQRパラメータを使用 -->
  <param name="speed_threshold_mid"  value="35.0"/>           <!-- 中速域上限[km/h] : この値未満で中速LQRパラメータを使用 -->
  <param name="speed_threshold_high" value="40.0"/>           <!-- 高速域下限[km/h] : 未使用 -->
  
  <!-- ヒステリシス・ブレンドパラメータ -->
  <param name="hysteresis_half_width"  value="1.5"/>          <!-- ヒステリシス半幅[km/h] : 速度閾値±この値でヒステリシス帯域 -->
  <param name="enable_linear_blending" value="true"/>         <!-- 線形ブレンド有効化 : true=パラメータを線形補間、false=段階的切替 -->
  
  <!-- 速度依存制御パラメータ -->
  <param name="velocity_gain_scale_base" value="10.0"/>       <!-- 速度ゲインスケール基準値[m/s] : velocity_scale = 1/(1 + velocity/この値) -->
  <param name="velocity_limit_threshold" value="15.0"/>       <!-- 速度制限切り替え閾値[m/s] : この値を超えると厳しい制限を適用 -->
  <param name="max_steering_high_speed" value="0.10"/>        <!-- 高速時最大ステアリング[rad] : 速度閾値超過時の制限値(±5.7度) -->
  <param name="max_steering_low_speed" value="0.20"/>         <!-- 低速時最大ステアリング[rad] : 速度閾値未満時の制限値(±11.5度) -->
  
  <!-- LQRパラメータ -->
  <!-- 低速域LQRパラメータ (< 15km/h) - 軌道追従強化 -->
  <param name="lqr_q_e_low"       value="1.2"/>               <!-- 横方向誤差重み         : 大きくすると経路追従精度向上、小さくすると穏やか -->
  <param name="lqr_q_e_dot_low"   value="0.6"/>               <!-- 横方向誤差微分重み      : 大きくすると振動抑制、小さくすると応答性向上 -->
  <param name="lqr_q_th_low"      value="1.0"/>               <!-- 方位角誤差重み         : 大きくすると方向追従精度向上、小さくすると穏やか -->
  <param name="lqr_q_th_dot_low"  value="0.4"/>               <!-- 方位角誤差微分重み      : 大きくすると方向変化の振動抑制 -->
  <param name="lqr_r_low"         value="2.0"/>               <!-- 制御入力重み           : 大きくするとステアリング動作が穏やか、小さくすると積極的 -->
  <!-- 中速域LQRパラメータ (15-25km/h) - 積極的追従 -->
  <param name="lqr_q_e_mid"       value="1.2"/>               <!-- 横方向誤差重み    -->
  <param name="lqr_q_e_dot_mid"   value="0.9"/>               <!-- 横方向誤差微分重み lateral_error -->
  <param name="lqr_q_th_mid"      value="3.0"/>               <!-- 方位角誤差重み    -->
  <param name="lqr_q_th_dot_mid"  value="0.6"/>               <!-- 方位角誤差微分重み heading_error -->
  <param name="lqr_r_mid"         value="0.6"/>               <!-- 制御入力重み      -->
  <!-- 高速域LQRパラメータ (> 25km/h) - 高精度追従 -->
  <param name="lqr_q_e_high"      value="4.5"/>               <!-- 横方向誤差重み    -->
  <param name="lqr_q_e_dot_high"  value="0.9"/>               <!-- 横方向誤差微分重み -->
  <param name="lqr_q_th_high"     value="3.0"/>               <!-- 方位角誤差重み    -->
  <param name="lqr_q_th_dot_high" value="0.6"/>               <!-- 方位角誤差微分重み -->
  <param name="lqr_r_high"        value="0.6"/>               <!-- 制御入力重み      -->
  <!-- 
    LQR制御式    : u = -K * x = -[K_lat, K_lat_dot, K_head, K_head_dot] * [lat_err, lat_err_dot, head_err, head_err_dot]
    実際の制御式  :
      steering_output = -(K_lat * lateral_error + K_lat_dot * lateral_error_dot + K_head * heading_error + K_head_dot * heading_error_dot)
    
    lqr_q_e_XXX     : 横方向誤差(lateral_error)の重み
    - 計算式での役割: Q行列のQ(0,0)要素として使用
    - ゲイン計算: K_lat ≈ lqr_q_e_XXX / (lqr_r_XXX + α) * β
    - 効果: 大きくすると横方向誤差修正が積極的になり、経路追従精度が向上
    - 中速域値4.5は積極的な軌道追従を意図
    
    lqr_q_e_dot_XXX : 横方向誤差微分(lateral_error_dot)の重み  
    - 計算式での役割: Q行列のQ(1,1)要素として使用
    - ゲイン計算: K_lat_dot ≈ lqr_q_e_dot_XXX / (lqr_r_XXX + α) * β
    - 効果: 大きくすると横方向の振動抑制、小さくすると応答性向上
    - 中速域値0.9は安定性と応答性のバランス調整
    
    lqr_q_th_XXX    : 方位角誤差(heading_error)の重み
    - 計算式での役割: Q行列のQ(2,2)要素として使用
    - ゲイン計算: K_head ≈ lqr_q_th_XXX / (lqr_r_XXX + α) * β
    - 効果: 大きくすると方位角誤差修正が積極的になり、方向追従精度が向上
    - 中速域値3.0は方向制御の重要性を反映
    
    lqr_q_th_dot_XXX : 方位角誤差微分(heading_error_dot)の重み
    - 計算式での役割: Q行列のQ(3,3)要素として使用  
    - ゲイン計算: K_head_dot ≈ lqr_q_th_dot_XXX / (lqr_r_XXX + α) * β
    - 効果: 大きくすると方位角変化の振動抑制、小さくすると方向応答性向上
    - 中速域値0.6は方向安定性の確保
    
    lqr_r_XXX       : 制御入力(steering)の重み
    - 計算式での役割: R行列のR(0,0)要素として使用、ゲイン計算の分母に影響
    - ゲイン計算: K_all ∝ Q_elements / (lqr_r_XXX + α)
    - 効果: 大きくするとステアリング動作が穏やか、小さくすると積極的
    - 中速域値0.6は積極的制御を可能にする設定
  -->
  
  <!-- フィードフォワード制御 -->
  <param name="enable_feedforward" value="false"/>            <!-- フィードフォワード有効化: true=予測制御追加, false=フィードバックのみ -->
  <param name="feedforward_curvature_gain" value="0.8"/>      <!-- 曲率ゲイン　: 大きくすると曲率変化への予測対応が積極的 -->
  <param name="feedforward_velocity_gain" value="0.05"/>      <!-- 速度ゲイン　: 大きくすると速度変化への予測対応が積極的 -->
  <param name="feedforward_lateral_gain" value="0.5"/>        <!-- 横方向ゲイン: 大きくすると横方向誤差への予測補償が積極的 -->
  <param name="feedforward_max_angle" value="8.0"/>           <!-- フィードフォワード最大角度 [deg]: 大きくすると予測制御の上限が大きく -->
  
  <remap from="input/kinematics" to="/localization/kinematic_state"/>
  <remap from="input/trajectory" to="/planning/scenario_planning/trajectory"/>
  <remap from="output/control_cmd" to="/control/command/control_cmd"/>

  <!-- === パターン3: バランス最適化のための予測平滑化パラメータ === -->
  <param name="enable_predictive_control" value="true"/>
  <param name="steering_smoothing_factor" value="1.80"/>        <!-- オーバーステア抑制とレスポンス性の最適バランス -->
  <param name="max_steering_rate" value="1.70"/>                <!-- 急激な変化は抑制しつつ、必要な機敏さは保持 -->
  <param name="prediction_horizon" value="2.3"/>                <!-- 【パターン3】予測時間は軽度調整（バランス重視） -->
  <param name="curvature_lookahead_gain" value="2.0"/>          <!-- 先読みしすぎを防止しつつ、極端な短縮は避ける -->

  <!-- 循環軌道対応パラメータ（そのまま維持） -->
  <param name="enable_circular_trajectory" value="true"/>
  <param name="circular_search_distance_ratio" value="0.8"/>

</node>

  <!-- Map -->
  <group>
    <push-ros-namespace namespace="map"/>

    <!-- map_container -->
    <node_container pkg="rclcpp_components" exec="component_container" name="map_container" namespace="">

      <!-- map_loader::Lanelet2MapLoaderNode -->
      <composable_node pkg="map_loader" plugin="Lanelet2MapLoaderNode" name="lanelet2_map_loader" namespace="">
        <remap from="output/lanelet2_map" to="vector_map" />
        <param name="lanelet2_map_path" value="$(var map_path)/$(var lanelet2_map_file)" />
        <param from="$(find-pkg-share aichallenge_submit_launch)/config/map/lanelet2_map_loader.param.yaml" />
        <extra_arg name="use_intra_process_comms" value="false" />
      </composable_node>

      <!-- map_loader::Lanelet2MapVisualizationNode -->
      <composable_node pkg="map_loader" plugin="Lanelet2MapVisualizationNode" name="lanelet2_map_visualization" namespace="">
        <remap from="input/lanelet2_map" to="vector_map" />
        <remap from="output/lanelet2_map_marker" to="vector_map_marker" />
        <param name="lanelet2_map_path" value="$(var map_path)/$(var lanelet2_map_file)" />
        <param from="$(find-pkg-share aichallenge_submit_launch)/config/map/lanelet2_map_loader.param.yaml" />
        <extra_arg name="use_intra_process_comms" value="false" />
      </composable_node>

      <!-- map_tf_generator::VectorMapTFGeneratorNode -->
      <composable_node pkg="map_tf_generator" plugin="VectorMapTFGeneratorNode" name="vector_map_tf_generator" namespace="">
        <param name="map_frame" value="map" />
        <param name="viewer_frame" value="viewer" />
        <extra_arg name="use_intra_process_comms" value="false" />
      </composable_node>

    </node_container>

  </group> <!-- map -->

  <!-- vehicle -->
  <group if="$(var launch_vehicle_interface)">
    <include file="$(find-pkg-share raw_vehicle_cmd_converter)/launch/raw_vehicle_converter.launch.xml">
      <arg name="converter_param_path" value="$(find-pkg-share aichallenge_submit_launch)/config/converter.param.yaml"/>
      <arg name="csv_path_accel_map" value="$(find-pkg-share aichallenge_submit_launch)/data/accel_map.csv"/>
      <arg name="csv_path_brake_map" value="$(find-pkg-share aichallenge_submit_launch)/data/brake_map.csv"/>

      <arg name="max_throttle" value="1.0"/>
      <arg name="max_brake" value="1.0"/>
      <arg name="convert_accel_cmd" value="true"/>
      <arg name="convert_brake_cmd" value="true"/>
      <arg name="convert_steer_cmd" value="false"/>

      <arg name="input_control_cmd" value="/control/command/control_cmd"/>
      <arg name="input_odometry" value="/localization/kinematic_state"/>
      <arg name="input_steering" value="/vehicle/status/steering_status"/>
      <arg name="output_actuation_cmd" value="/control/command/actuation_cmd"/>
    </include>
  </group>

</launch>
